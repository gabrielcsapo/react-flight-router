{
  "name": "react-flight-router",
  "version": "0.4.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielcsapo/flight-router.git",
    "directory": "packages/react-flight-router"
  },
  "bin": {
    "react-flight-router": "./dist/bin/react-flight-router.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./src/client/framework-runtime.ts",
    "./dist/client/framework-runtime.js"
  ],
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client/index.d.ts"
      ],
      "client/entry": [
        "./dist/client/entry.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "dev": [
        "./dist/dev/index.d.ts"
      ],
      "build": [
        "./dist/build/index.d.ts"
      ],
      "router": [
        "./dist/router/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./client/entry": {
      "import": "./dist/client/entry.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./dev": {
      "types": "./dist/dev/index.d.ts",
      "import": "./dist/dev/index.js"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "import": "./dist/build/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && vitest run && node --test dist/server/worker-pool.test.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "happy-dom": "^20.8.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-webpack": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-server-dom-webpack": "^19.0.0",
    "vite": "^6.0.0 || ^7.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": false
    },
    "@vitejs/plugin-react": {
      "optional": false
    }
  }
}
