{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "unicorn"],
  "env": {
    "browser": true,
    "node": true
  },
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/.vite/**"]
}
